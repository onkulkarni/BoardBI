# Server-side encryption key for JIRA API tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# User-Agent header sent to JIRA.
JIRA_USER_AGENT=BoardBI/0.0.0

# API server port.
PORT=3001

# Prisma SQLite connection string.
DATABASE_URL="file:./dev.db"
